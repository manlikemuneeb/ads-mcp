{
  "tool": "linkedin.analytics.*",
  "doc_url": "https://learn.microsoft.com/en-us/linkedin/marketing/integrations/ads-reporting/ads-reporting-schema?view=li-lms-2026-04",
  "doc_version": "li-lms-2026-04",
  "max_fields": 20,
  "always_include": ["dateRange", "pivotValues"],
  "fields_full": [
    "dateRange",
    "pivotValues",
    "impressions",
    "clicks",
    "costInLocalCurrency",
    "costInUsd",
    "approximateMemberReach",
    "landingPageClicks",
    "shares",
    "follows",
    "likes",
    "comments",
    "totalEngagements",
    "videoViews",
    "videoFirstQuartileCompletions",
    "videoMidpointCompletions",
    "videoThirdQuartileCompletions",
    "videoCompletions",
    "externalWebsiteConversions"
  ],
  "fields_account_overview": [
    "impressions",
    "clicks",
    "costInLocalCurrency",
    "costInUsd",
    "approximateMemberReach",
    "landingPageClicks",
    "shares",
    "follows",
    "likes",
    "comments",
    "totalEngagements",
    "videoViews"
  ],
  "fields_campaigns_list": [
    "dateRange",
    "pivotValues",
    "impressions",
    "clicks",
    "costInLocalCurrency",
    "costInUsd",
    "landingPageClicks",
    "totalEngagements",
    "videoViews"
  ],
  "_notes": "LinkedIn caps at 20 fields per analytics request. always_include lists fields the response needs for entity context. Slot per tool so each tool requests only what it returns. To add a field after a LinkedIn release: edit this file, run `npm run build`, no code change needed in tool sources."
}
